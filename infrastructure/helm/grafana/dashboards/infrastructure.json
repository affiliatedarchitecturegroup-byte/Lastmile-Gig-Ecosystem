{
  "description": "Lastmile Gig - Infrastructure Dashboard: EKS nodes, Kafka lag, pod health",
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "EKS Nodes",
      "type": "stat",
      "targets": [{ "expr": "count(kube_node_info{cluster=\"lmg-production\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "Running Pods",
      "type": "stat",
      "targets": [{ "expr": "sum(kube_pod_status_phase{namespace=~\"lmg-.*\",phase=\"Running\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "title": "Failed Pods",
      "type": "stat",
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "sum(kube_pod_status_phase{namespace=~\"lmg-.*\",phase=\"Failed\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "title": "Pending Pods",
      "type": "stat",
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } },
      "targets": [{ "expr": "sum(kube_pod_status_phase{namespace=~\"lmg-.*\",phase=\"Pending\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "title": "Node CPU Utilisation",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
      "targets": [{ "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "title": "Node Memory Utilisation",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
      "targets": [{ "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "title": "Kafka Consumer Lag by Group",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } } },
      "targets": [{ "expr": "sum(kafka_consumergroup_lag) by (consumergroup)", "legendFormat": "{{consumergroup}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "title": "Kafka Messages/sec by Topic",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "msgs", "custom": { "drawStyle": "line", "fillOpacity": 15 } } },
      "targets": [{ "expr": "sum(rate(kafka_topic_partition_current_offset[5m])) by (topic)", "legendFormat": "{{topic}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 9,
      "title": "Pod Restarts (1h)",
      "type": "table",
      "targets": [{ "expr": "topk(10, increase(kube_pod_container_status_restarts_total{namespace=~\"lmg-.*\"}[1h]) > 0)", "refId": "A", "instant": true, "format": "table" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "title": "Container CPU Usage by Namespace",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"lmg-.*\"}[5m])) by (namespace)", "legendFormat": "{{namespace}}", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["lastmile-gig", "infrastructure"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Lastmile Gig - Infrastructure",
  "uid": "lmg-infrastructure",
  "version": 1
}
