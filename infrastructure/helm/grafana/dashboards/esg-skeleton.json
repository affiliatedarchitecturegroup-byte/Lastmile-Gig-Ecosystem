{
  "description": "Lastmile Gig - ESG Dashboard (Skeleton): Carbon kg/day, EV %, placeholder panels",
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "Carbon Emissions Today (kg CO2)",
      "type": "stat",
      "fieldConfig": { "defaults": { "unit": "kg", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 1000 }] } } },
      "targets": [{ "expr": "sum(increase(lmg_carbon_emissions_kg_total[24h]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "EV Fleet %",
      "type": "gauge",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 25 }, { "color": "green", "value": 50 }] } } },
      "targets": [{ "expr": "100 * sum(lmg_vehicles_total{fuel_type=\"electric\"}) / sum(lmg_vehicles_total)", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "title": "Solar Charge Sessions Today",
      "type": "stat",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "sum(increase(lmg_solar_charge_sessions_total[24h]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "title": "Carbon Saved vs ICE (kg)",
      "type": "stat",
      "fieldConfig": { "defaults": { "unit": "kg", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{ "expr": "sum(increase(lmg_carbon_saved_kg_total[24h]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "title": "Daily Carbon Emissions Trend",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "kg", "custom": { "drawStyle": "bars", "fillOpacity": 80 } } },
      "targets": [{ "expr": "sum(increase(lmg_carbon_emissions_kg_total[1d]))", "legendFormat": "CO2 (kg)", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "title": "Fleet Composition by Fuel Type",
      "type": "piechart",
      "targets": [{ "expr": "sum(lmg_vehicles_total) by (fuel_type)", "legendFormat": "{{fuel_type}}", "refId": "A" }]
    },
    {
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 12 },
      "id": 7,
      "title": "Upcoming ESG Features",
      "type": "text",
      "options": { "mode": "markdown", "content": "### Phase 3 ESG Enhancements\n- Carbon credit tokenisation (Polygon CDK)\n- DFI-aligned reporting\n- sefa ESG template\n- Solar station telemetry integration\n- CrewAI ESG report generation" }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["lastmile-gig", "esg", "sustainability"],
  "time": { "from": "now-7d", "to": "now" },
  "title": "Lastmile Gig - ESG (Skeleton)",
  "uid": "lmg-esg-skeleton",
  "version": 1
}
