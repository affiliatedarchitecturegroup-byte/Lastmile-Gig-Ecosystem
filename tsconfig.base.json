{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@lastmile-gig/shared-types": ["libs/shared-types/src/index.ts"],
      "@lastmile-gig/shared-utils": ["libs/shared-utils/src/index.ts"],
      "@lastmile-gig/shared-ui": ["libs/shared-ui/src/index.ts"],
      "@lastmile-gig/api-client": ["libs/api-client/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "tmp"]
}
