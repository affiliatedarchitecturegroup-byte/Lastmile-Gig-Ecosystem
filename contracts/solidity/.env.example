# Lastmile Gig Smart Contracts - Environment Variables
# Copy to .env and fill in values. NEVER commit the .env file.

# Deployer wallet private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Polygon CDK RPC endpoints
POLYGON_CDK_TESTNET_RPC=https://rpc.public.zkevm-test.net
POLYGON_CDK_MAINNET_RPC=https://zkevm-rpc.com

# Block explorer API key for contract verification
ETHERSCAN_API_KEY=

# Gas reporting
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# The Graph deployment
SUBGRAPH_DEPLOY_KEY=
SUBGRAPH_ENDPOINT=
