# ============================================================
# LASTMILE GIG - Environment Variables Template
# ============================================================
# Copy this file to .env.local for local development
# NEVER commit .env.local or any file with actual secrets
# Production secrets managed via HashiCorp Vault + AWS Secrets Manager
# ============================================================

# --- General ---
LMG_ENVIRONMENT=development
LMG_LOG_LEVEL=debug
LMG_AWS_REGION=af-south-1

# --- Supabase (PostgreSQL) ---
LMG_SUPABASE_URL=http://localhost:54321
LMG_SUPABASE_ANON_KEY=your-anon-key-here
LMG_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
LMG_DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- MongoDB Atlas ---
LMG_MONGODB_URI=mongodb://localhost:27017/lastmile-gig

# --- Upstash Redis ---
LMG_UPSTASH_REDIS_URL=redis://localhost:6379
LMG_UPSTASH_REDIS_TOKEN=

# --- Auth0 ---
LMG_AUTH0_DOMAIN=dev-lastmilegig.us.auth0.com
LMG_AUTH0_CLIENT_ID=your-client-id
LMG_AUTH0_CLIENT_SECRET=your-client-secret
LMG_AUTH0_AUDIENCE=https://api.lastmilegig.aagais.co.za

# --- AWS Cognito ---
LMG_COGNITO_USER_POOL_ID=
LMG_COGNITO_CLIENT_ID=

# --- Payment Gateways ---
LMG_PAYSTACK_SECRET_KEY=sk_test_xxx
LMG_PAYSTACK_PUBLIC_KEY=pk_test_xxx
LMG_STRIPE_SECRET_KEY=sk_test_xxx
LMG_STRIPE_PUBLIC_KEY=pk_test_xxx
LMG_OZOW_API_KEY=
LMG_OZOW_PRIVATE_KEY=
LMG_PEACH_ENTITY_ID=
LMG_PEACH_ACCESS_TOKEN=
LMG_FLUTTERWAVE_SECRET_KEY=

# --- Blockchain (Polygon CDK) ---
LMG_POLYGON_RPC_URL=https://rpc.cardona.zkevm-rpc.com
LMG_POLYGON_CHAIN_ID=2442

# --- AI & ML ---
LMG_BEDROCK_REGION=us-east-1
LMG_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet
LMG_PINECONE_API_KEY=
LMG_PINECONE_ENVIRONMENT=us-east-1
LMG_SAGEMAKER_ENDPOINT_DRIVER_SCORE=
LMG_SAGEMAKER_ENDPOINT_DEMAND_FORECAST=
LMG_SAGEMAKER_ENDPOINT_FRAUD_DETECT=

# --- CMS & Media ---
LMG_SANITY_PROJECT_ID=
LMG_SANITY_DATASET=production
LMG_SANITY_API_TOKEN=
LMG_CLOUDINARY_CLOUD_NAME=
LMG_CLOUDINARY_API_KEY=
LMG_CLOUDINARY_API_SECRET=

# --- Communications ---
LMG_TWILIO_ACCOUNT_SID=
LMG_TWILIO_AUTH_TOKEN=
LMG_TWILIO_PHONE_NUMBER=
LMG_SENDGRID_API_KEY=
LMG_FIREBASE_PROJECT_ID=

# --- Observability ---
LMG_SENTRY_DSN=
LMG_DATADOG_API_KEY=
LMG_PAGERDUTY_SERVICE_KEY=

# --- Kafka (local dev uses Docker) ---
LMG_KAFKA_BROKERS=localhost:9092
LMG_KAFKA_CLIENT_ID=lmg-dev

# --- Elasticsearch (OpenSearch) ---
LMG_OPENSEARCH_URL=http://localhost:9200

# --- HashiCorp Vault ---
LMG_VAULT_ADDR=http://localhost:8200
LMG_VAULT_TOKEN=dev-only-token

# --- Service Ports (local dev) ---
LMG_PORT_API_GATEWAY=3000
LMG_PORT_AUTH_SERVICE=3001
LMG_PORT_DRIVER_SERVICE=3002
LMG_PORT_ORDER_SERVICE=3003
LMG_PORT_FLEET_SERVICE=3004
LMG_PORT_STOREFRONT_SERVICE=3005
LMG_PORT_DISPATCH_ENGINE=4000
LMG_PORT_ROUTE_OPTIMIZER=4001
LMG_PORT_BLOCKCHAIN_SERVICE=5000
LMG_PORT_IOT_SERVICE=5001
LMG_PORT_PAYMENT_SERVICE=6000
LMG_PORT_LOGISTICS_SERVICE=6001
LMG_PORT_TRACKING_SERVICE=7000
LMG_PORT_COMMS_SERVICE=7001
LMG_PORT_AI_SERVICE=8000
LMG_PORT_AGENT_SERVICE=8001
LMG_PORT_ANALYTICS_SERVICE=8002
